{
    "catalog": "https://s3-west.nrp-nautilus.io/public-data/stac/catalog.json",
    "titiler_url": "https://titiler.nrp-nautilus.io",
    "mcp_url": "https://duckdb-mcp.nrp-nautilus.io/mcp",
    "default_basemap": "plain",
    "view": {
        "center": [0, 20],
        "zoom": 3,
        "globe": true
    },
    "welcome": {
        "message": "Hi! I can help you explore global wetlands data and control the map. Try asking:",
        "examples": [
            "Tell me about the datasets you access and how you work.",
            "Calculate vulnerable carbon stored in different wetlands of India?",
            "Show Ramsar sites meeting Criterion 9; explain the criterion",
            "Color Ramsar sites by the number of criteria they meet",
            "Rank the top 10 level-3 hydrobasins by wetland extent, carbon, and NCP, normalized. Explain methodology and show them on map."
        ]
    },
    "collections": [
        {
            "collection_id": "wetlands-global-unified",
            "group": "Wetlands",
            "assets": [
                {
                    "id": "glwd-main-class-cog",
                    "display_name": "Global Wetlands (GLWD v2)",
                    "visible": true,
                    "legend_type": "categorical"
                },
                {
                    "id": "ramsar-pmtiles",
                    "display_name": "Ramsar Sites",
                    "visible": true,
                    "default_style": {
                        "fill-color": "#FF1493",
                        "fill-opacity": 0.5
                    },
                    "tooltip_fields": ["Site name", "Country", "Area (ha)", "Wetland Type"]
                }
            ]
        },
        {
            "collection_id": "irrecoverable-carbon",
            "group": "Environment",
            "assets": [
                {
                    "id": "v2-vulnerable-2024-cog",
                    "display_name": "Vulnerable Carbon (2024)",
                    "visible": false,
                    "colormap": "reds"
                }
            ]
        },
        {
            "collection_id": "ncp-biodiversity",
            "group": "Environment",
            "assets": [
                {
                    "id": "ncp-biod-nathab-cog",
                    "display_name": "Nature's Contributions to People",
                    "visible": false,
                    "colormap": "viridis",
                    "rescale": "0,19",
                    "legend_label": "NCP Score"
                }
            ]
        },
        {
            "collection_id": "wdpa-december-2025",
            "group": "Protected Areas",
            "assets": [
                {
                    "id": "wdpa-pmtiles",
                    "display_name": "Protected Areas (WDPA)",
                    "visible": false,
                    "default_style": {
                        "fill-color": ["match", ["get", "IUCN_CAT"],
                            "Ia", "#26633A",
                            "Ib", "#26633A",
                            "II", "#3E9C47",
                            "III", "#7EB3D3",
                            "IV", "#7EB3D3",
                            "V", "#BDBDBD",
                            "VI", "#BDBDBD",
                            "#888888"
                        ],
                        "fill-opacity": 0.6
                    },
                    "tooltip_fields": ["NAME_ENG", "IUCN_CAT", "DESIG_ENG", "ISO3", "GIS_AREA", "STATUS_YR"]
                }
            ]
        },
        {
            "collection_id": "hydrobasins-v1c",
            "group": "Hydrology",
            "assets": [
                {
                    "id": "unified-pmtiles",
                    "display_name": "Watersheds (HydroBASINS)",
                    "visible": false,
                    "default_style": {
                        "fill-color": "rgba(0, 100, 200, 0.1)",
                        "fill-opacity": 0.3
                    },
                    "tooltip_fields": ["HYBAS_ID", "PFAF_ID", "UP_AREA", "SUB_AREA"],
                    "versions": [
                        { "label": "L3 – Major Basins", "asset_id": "level-03-pmtiles" },
                        { "label": "L4", "asset_id": "level-04-pmtiles" },
                        { "label": "L5", "asset_id": "level-05-pmtiles" },
                        { "label": "L6 – Sub-catchments", "asset_id": "unified-pmtiles" }
                    ],
                    "default_version": "L6 – Sub-catchments"
                }
            ]
        },
        {
            "collection_id": "overture-divisions",
            "group": "Reference",
            "assets": []
        },
        {
            "collection_id": "inaturalist-ranges",
            "group": "Biodiversity",
            "assets": []
        }
    ]
}
